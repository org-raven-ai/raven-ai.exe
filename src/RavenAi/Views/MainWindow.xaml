<Window x:Class="RavenAi.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RavenAi.ViewModels"
        Title="raven_ai"
        Width="420" Height="560"
        MinWidth="340" MinHeight="360"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="True"
        Background="{StaticResource WindowBg}"
        AllowsTransparency="False">
    <!-- NOTE: AllowsTransparency is explicitly False. A transparent (WS_EX_LAYERED) window
         can make SetWindowDisplayAffinity fail with error 8, defeating the whole app. -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- title bar -->
            <RowDefinition Height="Auto" />  <!-- protection warning banner -->
            <RowDefinition Height="*" />     <!-- chat / settings -->
        </Grid.RowDefinitions>

        <!-- ===== Title bar (drag to move) ===== -->
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid Margin="10,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🛡 raven_ai" FontWeight="Bold" FontSize="14"
                               Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                    <Ellipse Width="8" Height="8" Margin="8,0,0,0" VerticalAlignment="Center"
                             Fill="{Binding IsFullyHidden, Converter={StaticResource BoolToBubbleBrush}}"
                             ToolTip="{Binding ProtectionStatus}" />
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="Settings" Command="{Binding ToggleSettingsCommand}"
                            Background="Transparent" Padding="8,4" />
                    <Button Content="—" Click="Minimize_Click" Background="Transparent"
                            Padding="10,4" ToolTip="Minimize to tray" />
                    <Button Content="✕" Click="Close_Click" Background="Transparent" Padding="10,4" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Protection warning banner (loud, only when NOT fully hidden) ===== -->
        <Border Grid.Row="1" Background="{StaticResource WarnBrush}" Padding="10,8"
                Visibility="{Binding ShowProtectionWarning, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="⚠ Screen-capture protection is NOT fully active"
                           Foreground="White" FontWeight="Bold" TextWrapping="Wrap" />
                <TextBlock Text="{Binding ProtectionStatus}" Foreground="White"
                           TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- ===== Chat surface ===== -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Message list -->
            <ScrollViewer Grid.Row="0" x:Name="MessagesScroll" Margin="8" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Chat.Messages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="4" Padding="10,8" CornerRadius="10" MaxWidth="320"
                                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignment}}"
                                    Background="{Binding IsUser, Converter={StaticResource BoolToBubbleBrush}}">
                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                           Foreground="{StaticResource TextBrush}" />
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Error line -->
            <Border Grid.Row="1" Background="#3A1F1F" Padding="8,4" Margin="8,0"
                    Visibility="{Binding Chat.ErrorMessage, Converter={StaticResource StringToVisibility}}">
                <TextBlock Text="{Binding Chat.ErrorMessage}" Foreground="#FF8A80" TextWrapping="Wrap" FontSize="11" />
            </Border>

            <!-- Input row -->
            <Grid Grid.Row="2" Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" x:Name="MicButton" Command="{Binding Chat.ToggleVoiceCommand}"
                        Margin="0,0,6,0" Padding="10,6"
                        ToolTip="Push-to-talk (Ctrl+Shift+V)">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                            <Setter Property="Content" Value="🎙" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Chat.IsRecording}" Value="True">
                                    <Setter Property="Content" Value="⏺ Rec" />
                                    <Setter Property="Background" Value="{StaticResource WarnBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBox Grid.Column="1" Text="{Binding Chat.InputText, UpdateSourceTrigger=PropertyChanged}"
                         VerticalContentAlignment="Center" AcceptsReturn="False"
                         KeyDown="Input_KeyDown" />

                <Button Grid.Column="2" Content="Send" Command="{Binding Chat.SendCommand}"
                        Margin="6,0,0,0" />
            </Grid>
        </Grid>

        <!-- ===== Settings pane (overlay) ===== -->
        <Border Grid.Row="2" Background="{StaticResource WindowBg}"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibility}}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="16" DataContext="{Binding Settings}">
                    <TextBlock Text="Settings" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                    <TextBlock Text="API Key" Foreground="{StaticResource SubtleTextBrush}" />
                    <PasswordBox x:Name="ApiKeyBox" Margin="0,4,0,2" Padding="8,6"
                                 Background="{StaticResource PanelBg}" Foreground="{StaticResource TextBrush}" />
                    <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"
                               Text="Stored encrypted (DPAPI). Leave blank to keep the current key." />
                    <TextBlock Text="✓ A key is currently stored." Foreground="#7ED07E" FontSize="11" Margin="0,0,0,8"
                               Visibility="{Binding HasStoredKey, Converter={StaticResource BoolToVisibility}}" />

                    <TextBlock Text="Base URL" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBox Text="{Binding BaseUrl}" Margin="0,4,0,8" />

                    <TextBlock Text="Chat Model" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBox Text="{Binding Model}" Margin="0,4,0,8" />

                    <TextBlock Text="System Prompt" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBox Text="{Binding SystemPrompt}" Margin="0,4,0,8" AcceptsReturn="True" MinHeight="48"
                             TextWrapping="Wrap" />

                    <TextBlock Text="Speech-to-Text Model" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBox Text="{Binding SttModel}" Margin="0,4,0,8" />

                    <TextBlock Text="Text-to-Speech Model" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBox Text="{Binding TtsModel}" Margin="0,4,0,8" />

                    <TextBlock Text="TTS Voice" Foreground="{StaticResource SubtleTextBrush}" />
                    <TextBox Text="{Binding TtsVoice}" Margin="0,4,0,8" />

                    <CheckBox Content="Use Windows offline TTS (no network)" IsChecked="{Binding UseOfflineTts}"
                              Foreground="{StaticResource TextBrush}" Margin="0,4,0,12" />

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Save" Click="SaveSettings_Click" />
                        <Button Content="Clear Key" Command="{Binding ClearKeyCommand}" Margin="8,0,0,0"
                                Background="#555" />
                    </StackPanel>

                    <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SubtleTextBrush}"
                               Margin="0,10,0,0" FontSize="11" />
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
