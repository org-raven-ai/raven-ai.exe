<Application x:Class="RavenAi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:RavenAi.Views">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Shared value converters -->
            <views:BoolToAlignmentConverter x:Key="BoolToAlignment" />
            <views:BoolToBubbleBrushConverter x:Key="BoolToBubbleBrush" />
            <views:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <views:StringToVisibilityConverter x:Key="StringToVisibility" />

            <!-- Minimal dark palette -->
            <SolidColorBrush x:Key="WindowBg" Color="#1E1E22" />
            <SolidColorBrush x:Key="PanelBg" Color="#26262B" />
            <SolidColorBrush x:Key="AccentBrush" Color="#2F6FED" />
            <SolidColorBrush x:Key="TextBrush" Color="#F0F0F2" />
            <SolidColorBrush x:Key="SubtleTextBrush" Color="#9A9AA2" />
            <SolidColorBrush x:Key="WarnBrush" Color="#C0392B" />

            <Style TargetType="Button">
                <Setter Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="White" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="10,6" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{StaticResource PanelBg}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="#3A3A40" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
