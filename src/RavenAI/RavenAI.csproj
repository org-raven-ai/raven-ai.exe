<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- .NET 8 LTS per spec. WindowsDesktop 8.0 runtime is installed. -->
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <!-- WinForms is enabled ONLY for the system-tray NotifyIcon (WPF has no native tray API).
         All actual UI is WPF; no WinForms windows are used. -->
    <UseWindowsForms>true</UseWindowsForms>
    <LangVersion>latest</LangVersion>
    <AssemblyName>raven_ai</AssemblyName>
    <RootNamespace>RavenAI</RootNamespace>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Version>1.0.0</Version>

    <!-- Small trimmed self-contained publish knobs (used by dotnet publish) -->
    <RuntimeIdentifier Condition="'$(PublishSelfContained)' == 'true'">win-x64</RuntimeIdentifier>
    <SelfContained Condition="'$(PublishSelfContained)' == 'true'">true</SelfContained>
    <PublishSingleFile Condition="'$(PublishSelfContained)' == 'true'">true</PublishSingleFile>
    <!-- WPF cannot be fully trimmed; enable partial trimming only when asked -->
    <PublishTrimmed Condition="'$(PublishSelfContained)' == 'true'">false</PublishTrimmed>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.3.2" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="System.Speech" Version="8.0.0" />
  </ItemGroup>

</Project>
