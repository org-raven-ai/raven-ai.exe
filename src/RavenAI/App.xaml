<Application x:Class="RavenAI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:RavenAI.Views">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- night instrument design system: tokens, icons, and control styles -->
                <ResourceDictionary Source="Themes/NightInstrument.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Shared value converters -->
            <views:BoolToAlignmentConverter x:Key="BoolToAlignment" />
            <views:BoolToVisibilityConverter x:Key="BoolToVisibility" />
            <views:StringToVisibilityConverter x:Key="StringToVisibility" />
            <views:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
