<Window x:Class="RavenAI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:RavenAI.ViewModels"
        Title="raven_ai"
        WindowStartupLocation="Manual"
        Topmost="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="Transparent"
        AllowsTransparency="True">
    <!-- This window is a full-virtual-screen transparent overlay. It is kept click-through
         (WS_EX_TRANSPARENT) at ALL times: in pass-through mode every click/key falls to the app
         underneath, and in interactive mode a low-level mouse hook captures input and drives a
         painted fake cursor that does its own hit-testing against the floating panels below.
         AllowsTransparency stays True (a per-pixel WS_EX_LAYERED window) so the empty regions are
         genuinely transparent; SetWindowDisplayAffinity(WDA_EXCLUDEFROMCAPTURE) still hides it
         from captures on the app's target OS (verified at runtime; the watchdog + banner are the
         safety net). Bounds are set to VirtualScreen in code-behind.

         Two draggable cards sit side by side on RootCanvas: the transcription-staging window (left)
         and the agent chat window (right). Both share this single overlay HWND, so both inherit the
         capture exclusion and are clickable by the fake cursor in interactive mode. -->

    <Grid>
        <!-- Faint dim while interactive, so it's obvious input is being captured. Never hit-tested. -->
        <Rectangle Fill="#18000000" IsHitTestVisible="False"
                   Visibility="{Binding IsInteractive, Converter={StaticResource BoolToVisibility}}" />

        <!-- Absolute-positioned layer for the draggable floating cards. -->
        <Canvas x:Name="RootCanvas" Background="Transparent">

            <!-- ============================================================================= -->
            <!-- ===== Transcription-staging card (left; drag its title bar to move) ========= -->
            <!-- ============================================================================= -->
            <!-- Two live channels (system audio → left, microphone → right) transcribe in parallel.
                 Interim hypotheses show as italic "live" bubbles; once a phrase is committed it
                 settles into a timestamped message. Send flushes every staged message into the
                 agent chat and empties this window. -->
            <Border x:Name="StagingCard" Width="400" Height="560"
                    Background="{StaticResource WindowBg}" CornerRadius="10"
                    BorderBrush="#3A3A40" BorderThickness="1" DataContext="{Binding Speech}">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="0" Opacity="0.5" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- title bar -->
                        <RowDefinition Height="Auto" />  <!-- channel controls -->
                        <RowDefinition Height="*" />     <!-- staged messages -->
                        <RowDefinition Height="Auto" />  <!-- live (interim) bubbles -->
                        <RowDefinition Height="Auto" />  <!-- send / clear -->
                    </Grid.RowDefinitions>

                    <!-- Title bar (drag to move via the fake cursor while interactive) -->
                    <Border x:Name="StagingTitleBar" Grid.Row="0" Background="{StaticResource PanelBg}"
                            CornerRadius="10,10,0,0">
                        <TextBlock Text="🎙 Transcription" FontWeight="Bold" FontSize="14" Margin="12,8"
                                   Foreground="{StaticResource TextBrush}" />
                    </Border>

                    <!-- Channel controls: start/stop each channel + choose the microphone. -->
                    <StackPanel Grid.Row="1" Margin="12,10,12,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- System-audio (Interviewer) start/stop + status -->
                            <StackPanel Grid.Column="0">
                                <Button Command="{Binding Interviewer.ToggleCommand}" FontWeight="Bold" HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Content" Value="▶ System audio" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Interviewer.IsListening}" Value="True">
                                                    <Setter Property="Content" Value="■ System audio" />
                                                    <Setter Property="Background" Value="{StaticResource WarnBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Text="{Binding Interviewer.Status}" Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="11" Margin="2,4,0,0" />
                            </StackPanel>

                            <!-- Microphone (You) start/stop + status -->
                            <StackPanel Grid.Column="2">
                                <Button Command="{Binding You.ToggleCommand}" FontWeight="Bold" HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                            <Setter Property="Content" Value="▶ Microphone" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding You.IsListening}" Value="True">
                                                    <Setter Property="Content" Value="■ Microphone" />
                                                    <Setter Property="Background" Value="{StaticResource WarnBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                                <TextBlock Text="{Binding You.Status}" Foreground="{StaticResource SubtleTextBrush}"
                                           FontSize="11" Margin="2,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <!-- Microphone picker: disabled while listening (a restart is needed to switch). -->
                        <Grid Margin="0,8,0,0" IsEnabled="{Binding You.CanSelectMicrophone}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0" ItemsSource="{Binding You.Microphones}"
                                      SelectedItem="{Binding You.SelectedMicrophone, Mode=TwoWay}"
                                      DisplayMemberPath="Name" ToolTip="Choose which microphone to listen to" />
                            <Button Grid.Column="1" Content="⟳" Command="{Binding You.RefreshMicrophonesCommand}"
                                    Margin="6,0,0,0" Padding="10,4" ToolTip="Refresh microphone list" />
                        </Grid>
                    </StackPanel>

                    <!-- Staged (committed) messages: system audio left, microphone right, in completion order. -->
                    <ScrollViewer Grid.Row="2" x:Name="StagingScroll" Margin="8,6" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Staged}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="4,3"
                                                HorizontalAlignment="{Binding IsMic, Converter={StaticResource BoolToAlignment}}">
                                        <Border Padding="10,8" CornerRadius="10" MaxWidth="300"
                                                Background="{Binding IsMic, Converter={StaticResource BoolToBubbleBrush}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Speaker}" FontSize="10" FontWeight="Bold"
                                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,2" />
                                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextBrush}" FontSize="13" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="{Binding TimeText}" FontSize="10" Margin="4,1,4,0"
                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                   HorizontalAlignment="{Binding IsMic, Converter={StaticResource BoolToAlignment}}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Live interim bubbles: one per channel, shown only while that channel has an in-progress
                         hypothesis. They vanish as the phrase settles into a staged message above. -->
                    <StackPanel Grid.Row="3" Margin="12,0,12,4">
                        <Border HorizontalAlignment="Left" Padding="10,8" CornerRadius="10" MaxWidth="300" Margin="0,2"
                                Background="{StaticResource PanelBg}" BorderBrush="#3A3A40" BorderThickness="1"
                                Visibility="{Binding Interviewer.InterimText, Converter={StaticResource StringToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="Interviewer · live" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,2" />
                                <TextBlock Text="{Binding Interviewer.InterimText}" TextWrapping="Wrap" FontStyle="Italic"
                                           Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            </StackPanel>
                        </Border>
                        <Border HorizontalAlignment="Right" Padding="10,8" CornerRadius="10" MaxWidth="300" Margin="0,2"
                                Background="{StaticResource PanelBg}" BorderBrush="#3A3A40" BorderThickness="1"
                                Visibility="{Binding You.InterimText, Converter={StaticResource StringToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="You · live" FontSize="10" FontWeight="Bold"
                                           Foreground="{StaticResource SubtleTextBrush}" Margin="0,0,0,2" />
                                <TextBlock Text="{Binding You.InterimText}" TextWrapping="Wrap" FontStyle="Italic"
                                           Foreground="{StaticResource SubtleTextBrush}" FontSize="13" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Send / Clear the staged batch. -->
                    <Grid Grid.Row="4" Margin="12,4,12,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Clear" Command="{Binding ClearStagedCommand}" Background="#555" />
                        <Button Grid.Column="2" Content="Send to agent →" Command="{Binding SendCommand}"
                                FontWeight="Bold"
                                ToolTip="Send all staged transcriptions to the assistant and clear this window" />
                    </Grid>
                </Grid>
            </Border>

            <!-- ============================================================================= -->
            <!-- ===== Agent chat card (right; drag its title bar to move) =================== -->
            <!-- ============================================================================= -->
            <Border x:Name="ChatCard" Width="420" Height="560"
                    Background="{StaticResource WindowBg}" CornerRadius="10"
                    BorderBrush="#3A3A40" BorderThickness="1">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="0" Opacity="0.5" />
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- title bar -->
                        <RowDefinition Height="Auto" />  <!-- protection warning banner -->
                        <RowDefinition Height="*" />     <!-- chat / settings / logs -->
                    </Grid.RowDefinitions>

                    <!-- ===== Title bar (drag to move via the fake cursor while interactive) ===== -->
                    <Border x:Name="ChatTitleBar" Grid.Row="0" Background="{StaticResource PanelBg}"
                            CornerRadius="10,10,0,0">
                        <Grid Margin="10,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="🛡 raven_ai" FontWeight="Bold" FontSize="14"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Ellipse Width="8" Height="8" Margin="8,0,0,0" VerticalAlignment="Center"
                                         Fill="{Binding IsFullyHidden, Converter={StaticResource BoolToBubbleBrush}}"
                                         ToolTip="{Binding ProtectionStatus}" />
                                <Border Margin="8,0,0,0" Padding="6,1" CornerRadius="4"
                                        Background="{StaticResource AccentBrush}"
                                        Visibility="{Binding IsInteractive, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="INTERACTIVE" FontSize="10" FontWeight="Bold"
                                               Foreground="White" VerticalAlignment="Center" />
                                </Border>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <Button Content="Logs" Command="{Binding ToggleLogCommand}"
                                        Background="Transparent" Padding="8,4" />
                                <Button Content="Settings" Command="{Binding ToggleSettingsCommand}"
                                        Background="Transparent" Padding="8,4" />
                                <Button Content="—" Click="Minimize_Click" Background="Transparent"
                                        Padding="10,4" ToolTip="Hide (Ctrl+Shift+Space to show)" />
                                <Button Content="✕" Click="Close_Click" Background="Transparent"
                                        Padding="10,4" ToolTip="Quit" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- ===== Protection warning banner (loud, only when NOT fully hidden) ===== -->
                    <Border Grid.Row="1" Background="{StaticResource WarnBrush}" Padding="10,8"
                            Visibility="{Binding ShowProtectionWarning, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="⚠ Screen-capture protection is NOT fully active"
                                       Foreground="White" FontWeight="Bold" TextWrapping="Wrap" />
                            <TextBlock Text="{Binding ProtectionStatus}" Foreground="White"
                                       TextWrapping="Wrap" FontSize="11" Margin="0,2,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- ===== Chat surface (display-only; all input comes from the staging window) ===== -->
                    <Grid Grid.Row="2"
                          Visibility="{Binding IsChatOpen, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Message list -->
                        <ScrollViewer Grid.Row="0" x:Name="MessagesScroll" Margin="8" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Chat.Messages}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="4" Padding="10,8" CornerRadius="10" MaxWidth="320"
                                                HorizontalAlignment="{Binding IsUser, Converter={StaticResource BoolToAlignment}}"
                                                Background="{Binding IsUser, Converter={StaticResource BoolToBubbleBrush}}">
                                            <TextBlock Text="{Binding Content}" TextWrapping="Wrap"
                                                       Foreground="{StaticResource TextBrush}" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Error line -->
                        <Border Grid.Row="1" Background="#3A1F1F" Padding="8,4" Margin="8,0,8,8"
                                Visibility="{Binding Chat.ErrorMessage, Converter={StaticResource StringToVisibility}}">
                            <TextBlock Text="{Binding Chat.ErrorMessage}" Foreground="#FF8A80" TextWrapping="Wrap" FontSize="11" />
                        </Border>
                    </Grid>

                    <!-- ===== Log panel (overlay) ===== -->
                    <!-- Live view of the unified logger: every error/exception/event, mirrored from the same
                         sink that writes the log file. Newest entries append at the bottom. -->
                    <Border Grid.Row="2" Background="{StaticResource WindowBg}"
                            Visibility="{Binding IsLogOpen, Converter={StaticResource BoolToVisibility}}">
                        <Grid DataContext="{Binding Log}" Margin="16,16,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />  <!-- header + actions -->
                                <RowDefinition Height="*" />     <!-- entry list -->
                                <RowDefinition Height="Auto" />  <!-- file path footer -->
                            </Grid.RowDefinitions>

                            <!-- Header row -->
                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0" Text="Logs" FontSize="16" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" VerticalAlignment="Center" />
                                <Button Grid.Column="1" Content="Copy" Command="{Binding CopyAllCommand}"
                                        Padding="10,4" Margin="6,0,0,0" Background="#555" />
                                <Button Grid.Column="2" Content="Folder" Command="{Binding OpenLogFolderCommand}"
                                        Padding="10,4" Margin="6,0,0,0" Background="#555"
                                        ToolTip="Open the log file's folder" />
                                <Button Grid.Column="3" Content="Clear" Command="{Binding ClearCommand}"
                                        Padding="10,4" Margin="6,0,0,0" Background="#555"
                                        ToolTip="Clear the on-screen list (the file is not touched)" />
                            </Grid>

                            <!-- Entry list. Auto-scrolls to newest via ScrollViewer in code-behind if needed;
                                 here we simply rely on the list growing downward. -->
                            <Border Grid.Row="1" Background="{StaticResource PanelBg}" CornerRadius="6" Padding="4">
                                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding Entries}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0" Text="{Binding TimeText}"
                                                               Foreground="{StaticResource SubtleTextBrush}"
                                                               FontFamily="Consolas" FontSize="11"
                                                               VerticalAlignment="Top" Margin="0,0,8,0" />
                                                    <TextBlock Grid.Column="1" Text="{Binding LevelText}"
                                                               Foreground="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                                                               FontFamily="Consolas" FontSize="11" FontWeight="Bold"
                                                               VerticalAlignment="Top" Margin="0,0,8,0" />
                                                    <StackPanel Grid.Column="2">
                                                        <TextBlock TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{StaticResource TextBrush}">
                                                            <Run Text="{Binding Category, Mode=OneWay}" FontWeight="Bold"
                                                                 Foreground="{StaticResource SubtleTextBrush}" />
                                                            <Run Text="  " />
                                                            <Run Text="{Binding Message, Mode=OneWay}" />
                                                        </TextBlock>
                                                        <TextBlock Text="{Binding Detail}" TextWrapping="Wrap"
                                                                   FontFamily="Consolas" FontSize="11"
                                                                   Foreground="{StaticResource SubtleTextBrush}"
                                                                   Margin="0,2,0,0"
                                                                   Visibility="{Binding HasDetail, Converter={StaticResource BoolToVisibility}}" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Border>

                            <TextBlock Grid.Row="2" Text="{Binding LogFilePath}" FontSize="11"
                                       Foreground="{StaticResource SubtleTextBrush}" TextTrimming="CharacterEllipsis"
                                       Margin="0,8,0,0" ToolTip="{Binding LogFilePath}" />
                        </Grid>
                    </Border>

                    <!-- ===== Settings pane (overlay) ===== -->
                    <Border Grid.Row="2" Background="{StaticResource WindowBg}"
                            Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolToVisibility}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16" DataContext="{Binding Settings}">
                                <TextBlock Text="Settings" FontSize="18" FontWeight="Bold"
                                           Foreground="{StaticResource TextBrush}" Margin="0,0,0,12" />

                                <TextBlock Text="API Key" Foreground="{StaticResource SubtleTextBrush}" />
                                <PasswordBox x:Name="APIKeyBox" Margin="0,4,0,2" Padding="8,6"
                                             Background="{StaticResource PanelBg}" Foreground="{StaticResource TextBrush}" />
                                <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"
                                           Text="Stored encrypted (DPAPI). Leave blank to keep the current key." />
                                <TextBlock Text="✓ A key is currently stored." Foreground="#7ED07E" FontSize="11" Margin="0,0,0,8"
                                           Visibility="{Binding HasStoredKey, Converter={StaticResource BoolToVisibility}}" />

                                <TextBlock Text="Base URL" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBox Text="{Binding BaseURL}" Margin="0,4,0,8" />

                                <!-- Model dropdowns are editable: they list the ids fetched from the provider's
                                     /models endpoint (the ⟳ button, or auto-loaded when Settings first opens),
                                     but a custom id can still be typed for providers that don't list one. -->
                                <TextBlock Text="Chat Model" Foreground="{StaticResource SubtleTextBrush}" />
                                <Grid Margin="0,4,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" IsEditable="True" IsTextSearchEnabled="True"
                                              ItemsSource="{Binding AvailableModels}"
                                              Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Content="⟳" Command="{Binding RefreshModelsCommand}"
                                            Margin="6,0,0,0" Padding="10,4"
                                            ToolTip="Fetch available models from your provider" />
                                </Grid>

                                <TextBlock Text="System Prompt" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBox Text="{Binding SystemPrompt}" Margin="0,4,0,8" AcceptsReturn="True" MinHeight="48"
                                         TextWrapping="Wrap" />

                                <TextBlock Text="Speech-to-Text Model" Foreground="{StaticResource SubtleTextBrush}" />
                                <ComboBox IsEditable="True" IsTextSearchEnabled="True" Margin="0,4,0,8"
                                          ItemsSource="{Binding AvailableModels}"
                                          Text="{Binding STTModel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="Text-to-Speech Model" Foreground="{StaticResource SubtleTextBrush}" />
                                <ComboBox IsEditable="True" IsTextSearchEnabled="True" Margin="0,4,0,8"
                                          ItemsSource="{Binding AvailableModels}"
                                          Text="{Binding TTSModel, UpdateSourceTrigger=PropertyChanged}" />

                                <TextBlock Text="TTS Voice" Foreground="{StaticResource SubtleTextBrush}" />
                                <TextBox Text="{Binding TTSVoice}" Margin="0,4,0,8" />

                                <CheckBox Content="Use Windows offline TTS (no network)" IsChecked="{Binding UseOfflineTTS}"
                                          Foreground="{StaticResource TextBrush}" Margin="0,4,0,12" />

                                <!-- ===== Azure Speech (speech-to-text) ===== -->
                                <Border BorderBrush="{StaticResource PanelBg}" BorderThickness="0,1,0,0"
                                        Margin="0,4,0,12" Padding="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Azure Speech (Speech-to-Text)" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                                        <TextBlock Text="Azure Speech Key" Foreground="{StaticResource SubtleTextBrush}" />
                                        <PasswordBox x:Name="AzureSpeechKeyBox" Margin="0,4,0,2" Padding="8,6"
                                                     Background="{StaticResource PanelBg}" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"
                                                   Text="Stored encrypted (DPAPI). Leave blank to keep the current key." />
                                        <TextBlock Text="✓ An Azure key is currently stored." Foreground="#7ED07E" FontSize="11" Margin="0,0,0,8"
                                                   Visibility="{Binding HasStoredAzureSpeechKey, Converter={StaticResource BoolToVisibility}}" />

                                        <TextBlock Text="Endpoint / Region" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBox Text="{Binding AzureSpeechEndpoint}" Margin="0,4,0,2" />
                                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"
                                                   TextWrapping="Wrap"
                                                   Text="Full endpoint (e.g. https://eastus.api.cognitive.microsoft.com) or just a region (e.g. eastus)." />

                                        <TextBlock Text="Recognition Language" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBox Text="{Binding AzureSpeechRecognitionLanguage}" Margin="0,4,0,8" />

                                        <Button Content="Clear Azure Key" Command="{Binding ClearAzureKeyCommand}"
                                                Background="#555" HorizontalAlignment="Left" Padding="10,4" />
                                    </StackPanel>
                                </Border>

                                <!-- ===== Web Search (assistant tool) ===== -->
                                <Border BorderBrush="{StaticResource PanelBg}" BorderThickness="0,1,0,0"
                                        Margin="0,4,0,12" Padding="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Web Search (Tavily)" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" Margin="0,0,0,8" />

                                        <TextBlock Text="Tavily API Key" Foreground="{StaticResource SubtleTextBrush}" />
                                        <PasswordBox x:Name="WebSearchKeyBox" Margin="0,4,0,2" Padding="8,6"
                                                     Background="{StaticResource PanelBg}" Foreground="{StaticResource TextBrush}" />
                                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"
                                                   TextWrapping="Wrap"
                                                   Text="Enables the assistant's web_search tool. Stored encrypted (DPAPI). Leave blank to keep the current key." />
                                        <TextBlock Text="✓ A web-search key is currently stored." Foreground="#7ED07E" FontSize="11" Margin="0,0,0,8"
                                                   Visibility="{Binding HasStoredWebSearchKey, Converter={StaticResource BoolToVisibility}}" />

                                        <TextBlock Text="Endpoint" Foreground="{StaticResource SubtleTextBrush}" />
                                        <TextBox Text="{Binding WebSearchEndpoint}" Margin="0,4,0,2" />
                                        <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,8"
                                                   TextWrapping="Wrap"
                                                   Text="Tavily-compatible search endpoint (default https://api.tavily.com/search)." />

                                        <Button Content="Clear Web-Search Key" Command="{Binding ClearWebSearchKeyCommand}"
                                                Background="#555" HorizontalAlignment="Left" Padding="10,4" />
                                    </StackPanel>
                                </Border>

                                <!-- ===== Window transparency ===== -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Window transparency"
                                               Foreground="{StaticResource SubtleTextBrush}" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"
                                               Text="{Binding WindowOpacity, StringFormat={}{0}%}" />
                                </Grid>
                                <Slider Minimum="30" Maximum="100" TickFrequency="10" IsSnapToTickEnabled="False"
                                        Value="{Binding WindowOpacity, Mode=TwoWay}" Margin="0,0,0,4" />
                                <TextBlock Foreground="{StaticResource SubtleTextBrush}" FontSize="11" Margin="0,0,0,12"
                                           TextWrapping="Wrap"
                                           Text="Fades the whole window on your screen, applied live. The window stays hidden from screen shares/recordings — watch the status dot in the title bar; if it ever turns red, the warning banner explains that protection is off." />

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Save" Click="SaveSettings_Click" />
                                    <Button Content="Clear Key" Command="{Binding ClearKeyCommand}" Margin="8,0,0,0"
                                            Background="#555" />
                                </StackPanel>

                                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SubtleTextBrush}"
                                           Margin="0,10,0,0" FontSize="11" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Border>
        </Canvas>

        <!-- ===== Interactive-mode hint (top-center) ===== -->
        <Border VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,14,0,0"
                Background="#CC26262B" CornerRadius="16" Padding="14,7" IsHitTestVisible="False"
                Visibility="{Binding IsInteractive, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Foreground="{StaticResource TextBrush}" FontSize="12"
                       Text="Interactive mode — real cursor frozen · Esc or Ctrl+Shift+I to exit" />
        </Border>

        <!-- ===== Fake cursor layer (painted; drawn on top of everything) ===== -->
        <Canvas x:Name="CursorLayer" IsHitTestVisible="False"
                Visibility="{Binding IsInteractive, Converter={StaticResource BoolToVisibility}}">
            <!-- The genuine OS cursor bitmap (arrow / I-beam / hand) rendered by the code-behind and
                 positioned so its hot-spot lands on the fake-cursor point via FakeCursorTransform. -->
            <Image x:Name="FakeCursorImage" Stretch="Uniform" SnapsToDevicePixels="True"
                   RenderOptions.BitmapScalingMode="HighQuality">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="FakeCursorTransform" X="0" Y="0" />
                </Image.RenderTransform>
            </Image>
        </Canvas>
    </Grid>
</Window>
